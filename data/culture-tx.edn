#:culture{:id "ton.dish.lu-pulu", :name "Lū Pulu", :country "TON", :kind :dish, :summary "Tongan parcel dish of taro leaves (lu talo) wrapped around corned beef and coconut cream; the Wikipedia Luʻau article's Tonga section describes lu pulu specifically, while noting taro-leaf luʻau-style dishes are found across several Pacific nations.", :url "https://en.wikipedia.org/wiki/L%C5%AB%CA%BBau_(food)", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.dish.topai", :name "Topai", :country "TON", :kind :dish, :summary "Tongan dish of flour and water worked into a paste and dropped into boiling water, then served with a syrup of sugar and coconut milk, per the Wikipedia article on Tongan cuisine.", :url "https://en.wikipedia.org/wiki/Tongan_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.dish.ma", :name "Mā", :country "TON", :kind :dish, :summary "Traditional Tongan preserve of breadfruit, banana, and taro stored in pits until fermented into a staple food, per the Wikipedia article on Tongan cuisine.", :url "https://en.wikipedia.org/wiki/Tongan_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.beverage.otai", :name "ʻOtai", :country "TON", :kind :beverage, :summary "Popular Tongan drink of pulped watermelon mixed with coconut milk, per the Wikipedia article on Tongan cuisine.", :url "https://en.wikipedia.org/wiki/Tongan_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.beverage.kava", :name "Kava", :country "TON", :kind :beverage, :summary "Ceremonial and social drink prepared from the kava plant's root; in Tonga it is drunk nightly at kalapu (\"clubs\") and a formal kava ceremony is a required component of the accession rites for a King of Tonga.", :url "https://en.wikipedia.org/wiki/Kava_culture", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.craft.ngatu", :name "Ngatu", :country "TON", :kind :craft, :summary "Tongan tapa cloth beaten from paper mulberry bark and painted with carved wooden drums (kupesi); families are considered poor if they lack ngatu to give at weddings, funerals, and other life events.", :url "https://en.wikipedia.org/wiki/Tapa_cloth", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ton.heritage.haamonga-a-maui", :name "Haʻamonga ʻa Maui", :country "TON", :kind :heritage, :summary "Stone trilithon on Tongatapu, built in the 13th century by King Tuʻitātui in honor of his two sons; sometimes called the \"Stonehenge of the Pacific\" and protected as a national park since 1972.", :url "https://en.wikipedia.org/wiki/Ha%CA%BBamonga_%CA%BBa_Maui", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
]
